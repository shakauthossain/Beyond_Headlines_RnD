# Beyond Headlines API — Environment Variables
# Copy this file to .env and fill in your values

# ── Server ───────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ── Database (overridden by docker-compose for container networking) ──────────
DATABASE_URL=postgresql://bh_user:bh_password@localhost:5432/beyond_headlines

# ── Redis (overridden by docker-compose for container networking) ─────────────
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────
JWT_SECRET=change-this-to-a-strong-secret

# ── AI — Single OpenRouter Key Covers All Models ──────────────────────────────
OPENROUTER_API_KEY=sk-or-...

# OpenRouter model identifiers
CLAUDE_SONNET_MODEL=anthropic/claude-sonnet-4-5
CLAUDE_HAIKU_MODEL=anthropic/claude-haiku-4-5
PERPLEXITY_SONAR_MODEL=perplexity/sonar-pro

# ── Workers ───────────────────────────────────────────
SCRAPE_INTERVAL_MS=1800000

# ── Cache TTLs ────────────────────────────────────────
CLUSTER_CACHE_TTL=1800
RESEARCH_CACHE_TTL=7200

# ── Postgres (used by docker-compose to init the DB) ─────────────────────────
POSTGRES_USER=bh_user
POSTGRES_PASSWORD=bh_password
POSTGRES_DB=beyond_headlines
