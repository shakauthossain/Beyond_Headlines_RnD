# Environment Configuration — Beyond Headlines API
# Copy this file to .env and fill in your values before running in production.

# ── JWT ─────────────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=beyond-headlines-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── App ──────────────────────────────────────────────────────────────────────────
APP_NAME="Beyond Headlines API"
APP_VERSION="1.0.0"
DEBUG=true
